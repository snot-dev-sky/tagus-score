{
  "name": "tagus-score",
  "version": "1.0.0",
  "description": "React + Express TypeScript boilerplate",
  "main": "dist/server/index.js",
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "start": "concurrently \"npm run db:start\" \"npm run dev:client\" \"npm run dev:server\"",
    "start:production": "node dist/server/index.js",
    "dev:client": "webpack serve --mode development",
    "dev:server": "ts-node-dev --respawn --files --project tsconfig.server.json src/server/index.ts",
    "db:start": "brew services start postgresql@17",
    "db:stop": "brew services stop postgresql@17",
    "build": "webpack --mode production && tsc --project tsconfig.server.json",
    "build:client": "webpack --mode production",
    "build:server": "tsc --project tsconfig.server.json",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "bcrypt": "^6.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.0.1",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.5.1",
    "postcss": "^8.5.10",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
