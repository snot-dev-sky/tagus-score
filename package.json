{
  "name": "tagus-score",
  "version": "1.0.0",
  "description": "React + Express TypeScript boilerplate",
  "main": "dist/server/index.js",
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "start": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "start:production": "node dist/server/index.js",
    "dev:client": "webpack serve --mode development",
    "dev:server": "ts-node src/server/index.ts",
    "build": "webpack --mode production && tsc --project tsconfig.server.json",
    "build:client": "webpack --mode production",
    "build:server": "tsc --project tsconfig.server.json",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "express": "^4.18.2",
    "framer-motion": "^12.38.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^25.5.2",
    "@types/react": "^18.0.31",
    "@types/react-dom": "^18.0.11",
    "concurrently": "^8.0.1",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.5.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
